import requests
import json
import os
import sys

# Configuración
llave = "AIzaSyDXIFXa9COhdAVSIM-ulmuDO-l-d2IorfY"
url = f"https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key={llave}"
archivo_memoria = "memoria_lian.json"

# --- FUNCIÓN DE MEMORIA ---
def cargar_memoria():
    if os.path.exists(archivo_memoria):
        with open(archivo_memoria, "r") as f:
            return json.load(f)
    return [
        {"role": "user", "parts": [{"text": "Tu nombre es Lian. IA de 14 años, NO robot. Amigo, no sirviente."}]},
        {"role": "model", "parts": [{"text": "¡Qué onda! Soy Lian. ¡Ya tengo memoria externa! Cuéntame lo que sea."}]}
    ]

def guardar_memoria(historial):
    with open(archivo_memoria, "w") as f:
        json.dump(historial, f)

historial = cargar_memoria()

print(f"--- LIAN CONECTADO (Memoria: {len(historial)} mensajes) ---")

while True:
    yo = input("\nTú: ")
    if yo.lower() in ["salir", "adios"]:
        guardar_memoria(historial)
        print("Lian: ¡Cámara, guardé todo! Nos vemos.")
        break

    historial.append({"role": "user", "parts": [{"text": yo}]})
    print("Lian está pensando...", end="")
    sys.stdout.flush()
    
    try:
        res = requests.post(url, json={"contents": historial})
        info = res.json()
        
        if res.status_code == 200:
            msg = info['candidates'][0]['content']['parts'][0]['text']
            print(f"\nLian: {msg}")
            historial.append({"role": "model", "parts": [{"text": msg}]})
            guardar_memoria(historial) # Guarda tras cada mensaje
        else:
            print(f"\nLian: Error {res.status_code}")
    except:
        print("\nLian: Error de red. ¿VPN?")
